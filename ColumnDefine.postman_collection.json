      "name": "12. 权限验证测试",
      "description": "验证普通用户无法访问管理员接口",
      "item": [
        {
          "name": "非 admin 用户访问管理接口 (预期 401)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 先获取 alice 的 token",
                  "pm.sendRequest({",
                  "  url: pm.variables.get('baseUrl') + '/api/auth/login',",
                  "  method: 'POST',",
                  "  header: { 'Content-Type': 'application/json' },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ username: 'alice', password: 'alice123' }) }",
                  "}, (err, res) => {",
                  "  const json = res.json();",
                  "  if (json.code === 200) {",
                  "    pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + json.data.token });",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"普通用户被 401 拦截\", () => {",
                  "  pm.expect(json.code).to.eql(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {

    {
      "name": "5. 用户个性化覆盖 (需登录)",
      "description": "这些接口需要 token，请先执行「认证」分组中的登录请求",
      "item": [
        {
          "name": "GET /api/overrides/{presetId} — 加载覆盖",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test(\"加载覆盖\", () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "  if (json.data) pm.expect(json.data.presetId).to.eql('p_hr_staff_default');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/overrides/p_hr_staff_default",
              "host": ["{{baseUrl}}"],
              "path": ["api", "overrides", "p_hr_staff_default"]
            }
          }
        },
        {
          "name": "PUT /api/overrides/{presetId} — 保存覆盖",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"presetId\": \"p_hr_staff_default\",\n  \"columnOverrides\": {\n    \"email\": {\n      \"order\": 0,\n      \"width\": 250,\n      \"visible\": true,\n      \"pinned\": null\n    },\n    \"phone\": {\n      \"order\": 1,\n      \"width\": 180,\n      \"visible\": false,\n      \"pinned\": null\n    }\n  },\n  \"version\": 1,\n  \"updatedAt\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/overrides/p_hr_staff_default",
              "host": ["{{baseUrl}}"],
              "path": ["api", "overrides", "p_hr_staff_default"]
            }
          }
        },
        {
          "name": "POST /api/overrides/{presetId}/share — 创建分享",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.code === 200 && json.data) {",
                  "  pm.collectionVariables.set('shareToken', json.data);",
                  "  console.log('分享 Token 已保存:', json.data);",
                  "}",
                  "pm.test(\"创建分享成功\", () => pm.expect(json.code).to.eql(200));"
                ],
                "type": "text/javascript"

{
  "info": {
    "name": "列自定义系统 API",
    "description": "Column Define System — 完整 API 集合\n\n包含 31 个接口，按模块分组：\n- 健康检查 (1)\n- 认证 (1)\n- 系统/业务/预设查询 (3)\n- 预设 (2)\n- 用户覆盖 (3)\n- 分享 (1)\n- 管理中心 (20)\n\n测试账号:\n  admin / admin123  (管理员)\n  alice / alice123  (普通用户)\n  bob   / bob123    (普通用户)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "cds"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "shareToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// 所有请求自动携带此预请求脚本",
          "// 如果当前请求未设置 Authorization，则使用 collection 级别的 Bearer token",
          ""
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. 健康检查",
      "item": [
        {
          "name": "GET /api/health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"状态码 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"返回 code=200\", () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.code).to.eql(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "2. 认证",
      "item": [
        {
          "name": "POST /api/auth/login — 管理员登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.code === 200) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token 已自动保存到 collectionVariables.token');",
                  "}",
                  "pm.test(\"登录成功\", () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "  pm.expect(json.data.token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "POST /api/auth/login — 普通用户登录 (alice)",
          "event": [
            {
              "listen": "test",
